# Application environment
APP_ENV=local
LOG_LEVEL=INFO

# Server configuration
HOST=0.0.0.0
PORT=8000

# LLM provider configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash

# API keys (set at least one based on provider)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional tuning
REQUEST_TIMEOUT_SECONDS=30
MAX_TITLES=10
DEFAULT_TITLES=8
TEMPERATURE=0.4
MAX_OUTPUT_TOKENS=2000
